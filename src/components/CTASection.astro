---
interface Props {
  title?: string;
  subtitle?: string;
  href?: string;
  btnText?: string;
}

const {
  title = 'Plan een gratis kennismaking',
  subtitle,
  href = '/contact',
  btnText = 'Neem contact op',
} = Astro.props;
---

<section class="bg-accent py-16 text-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4">{title}</h2>
    {subtitle && (
      <p class="text-white/85 text-lg leading-relaxed mb-8">{subtitle}</p>
    )}
    <a
      href={href}
      class="inline-block bg-white text-accent font-semibold px-8 py-3 rounded-full hover:bg-primary hover:text-white transition-colors shadow-md"
    >
      {btnText}
    </a>
  </div>
</section>
