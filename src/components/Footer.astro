---
---

<footer class="bg-primary text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Col 1: Logo + Tagline -->
      <div>
        <img src={`${import.meta.env.BASE_URL}/images/logo.png`} alt="Joep Lochtenberg" class="h-12 mb-4 brightness-0 invert" />
        <p class="text-white/80 text-sm leading-relaxed">
          Uw loopbaancoach in Hilversum
        </p>
        <p class="text-white/70 text-sm mt-3 leading-relaxed">
          Professionele begeleiding bij loopbaanvragen, re-integratie en outplacement. NOLOC gecertificeerd.
        </p>
      </div>

      <!-- Col 2: Snelle Links -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-white">Snelle links</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-white/80 hover:text-white transition-colors text-sm">Home</a></li>
          <li><a href="/loopbaancoaching/" class="text-white/80 hover:text-white transition-colors text-sm">Loopbaancoaching</a></li>
          <li><a href="/re-integratie/" class="text-white/80 hover:text-white transition-colors text-sm">Re-integratie</a></li>
          <li><a href="/outplacement" class="text-white/80 hover:text-white transition-colors text-sm">Outplacement</a></li>
          <li><a href="/werkenergieanalyse/" class="text-white/80 hover:text-white transition-colors text-sm">Werkenergieanalyse</a></li>
          <li><a href="/aanbevelingen" class="text-white/80 hover:text-white transition-colors text-sm">Aanbevelingen</a></li>
          <li><a href="/joep" class="text-white/80 hover:text-white transition-colors text-sm">Over Joep</a></li>
          <li><a href="/contact" class="text-white/80 hover:text-white transition-colors text-sm">Contact</a></li>
          <li><a href="/links" class="text-white/80 hover:text-white transition-colors text-sm">Links</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact Info -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-white">Contact</h3>
        <ul class="space-y-3 text-sm text-white/80">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Hilversum, Noord-Holland</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:06123456789" class="hover:text-white transition-colors">06-123 456 789</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:joep@joeplochtenberg.nl" class="hover:text-white transition-colors">joep@joeplochtenberg.nl</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-6 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/60">
      <p>© 2024 Joep Lochtenberg – Loopbaancoach in Hilversum</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/disclaimer" class="hover:text-white transition-colors">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>
