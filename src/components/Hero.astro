---
---

<section class="bg-primary text-white min-h-[80vh] flex items-center">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Text Left -->
      <div>
        <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Joep Lochtenberg –<br />
          <span class="text-gold">Loopbaancoach</span><br />
          in Hilversum
        </h1>
        <p class="text-white/85 text-xl leading-relaxed mb-8 max-w-lg">
          Professionele begeleiding bij loopbaanvragen, re-integratie en outplacement. Samen werken we aan uw optimale loopbaanpad.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={`${import.meta.env.BASE_URL}/contact`}
            class="bg-accent text-white font-semibold px-7 py-3 rounded-full hover:bg-white hover:text-accent transition-colors shadow-lg"
          >
            Gratis kennismaking
          </a>
          <a
            href="#diensten"
            class="border-2 border-white text-white font-semibold px-7 py-3 rounded-full hover:bg-white hover:text-primary transition-colors"
          >
            Ontdek de diensten
          </a>
        </div>
      </div>

      <!-- Photo Right -->
      <div class="flex justify-center lg:justify-end">
        <img
          src={`${import.meta.env.BASE_URL}/images/joep.jpg`}
          alt="Joep Lochtenberg"
          class="rounded-2xl shadow-2xl w-full max-w-md mx-auto"
        />
      </div>
    </div>

    <!-- Trust Strip -->
    <div class="mt-14 pt-10 border-t border-white/20 flex flex-wrap items-center justify-center gap-8">
      <div class="flex items-center gap-3">
        <img src={`${import.meta.env.BASE_URL}/images/rlp-badge.png`} alt="RLP gecertificeerd" class="h-12 w-auto" />
        <span class="text-white/80 text-sm font-semibold">RLP Gecertificeerd</span>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
        </div>
        <span class="text-white/80 text-sm font-semibold">NOLOC gecertificeerd</span>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="text-white/80 text-sm font-semibold">13+ jaar ervaring</span>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <span class="text-white/80 text-sm font-semibold">Gecertificeerd loopbaancoach</span>
      </div>
    </div>
  </div>
</section>
