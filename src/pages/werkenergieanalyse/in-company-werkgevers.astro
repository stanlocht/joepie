---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="In Company voor Werkgevers"
  description="Werkenergieanalyse In Company voor werkgevers. Joep Lochtenberg begeleidt teams en organisaties bij het versterken van vitaliteit en duurzame inzetbaarheid."
>

  <!-- Hero -->
  <section class="bg-primary text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-accent font-semibold uppercase text-sm tracking-wider mb-4 block">Werkenergieanalyse</span>
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-6">In Company voor Werkgevers</h1>
      <p class="text-white/85 text-xl leading-relaxed max-w-2xl mx-auto">
        Investeer in de vitaliteit van uw medewerkers. De werkenergieanalyse als strategisch instrument voor duurzame inzetbaarheid binnen uw organisatie.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-background py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading font-bold text-3xl text-primary mb-5">De werkenergieanalyse voor uw organisatie</h2>
          <p class="text-muted leading-relaxed mb-4">
            Vitale medewerkers zijn productiever, creatiever en minder vaak ziek. Ze zijn betrokken bij hun werk en blijven langer bij uw organisatie. Investeren in de vitaliteit van uw medewerkers is niet alleen goed voor hen – het is ook goed voor uw organisatie.
          </p>
          <p class="text-muted leading-relaxed mb-4">
            Met de in-company Werkenergieanalyse biedt u uw medewerkers een professioneel en persoonlijk instrument om inzicht te krijgen in hun werkenergie. De analyse wordt uitgevoerd op maat: afgestemd op uw organisatie, uw branche en uw specifieke vraagstukken.
          </p>
          <p class="text-muted leading-relaxed">
            De resultaten worden zowel op individueel niveau als – geanonimiseerd – op teamniveau gerapporteerd. Dit geeft u waardevolle inzichten in de collectieve energiehuishouding van uw teams.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-section-alt rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="font-heading font-semibold text-primary">Individuele analyse</h3>
            </div>
            <p class="text-muted text-sm">Elke medewerker ontvangt een persoonlijk rapport en individueel coachingsgesprek.</p>
          </div>
          <div class="bg-section-alt rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <h3 class="font-heading font-semibold text-primary">Teamrapportage</h3>
            </div>
            <p class="text-muted text-sm">Geanonimiseerde rapportage op teamniveau geeft inzicht in collectieve energiepatronen.</p>
          </div>
          <div class="bg-section-alt rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                </svg>
              </div>
              <h3 class="font-heading font-semibold text-primary">Presentatie & advies</h3>
            </div>
            <p class="text-muted text-sm">Presentatie van de teamresultaten aan management met concrete aanbevelingen voor beleid.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wat levert het op? -->
  <section class="bg-section-alt py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Wat levert het uw organisatie op?"
        subtitle="De in-company werkenergieanalyse heeft aantoonbare positieve effecten op uw organisatie."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { stat: '↓ 25%', label: 'Lager verzuim', desc: 'Vroeg signaleren en aanpakken van stressrisico\'s vermindert langdurig verzuim.' },
          { stat: '↑ 18%', label: 'Hogere productiviteit', desc: 'Vitale en bevlogen medewerkers leveren meetbaar betere prestaties.' },
          { stat: '↑ 30%', label: 'Meer betrokkenheid', desc: 'Medewerkers voelen zich gehoord en gezien. Dit vergroot hun betrokkenheid.' },
          { stat: '↓ 40%', label: 'Minder verloop', desc: 'Medewerkers die goed in hun vel zitten, vertrekken minder snel.' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-md text-center">
            <div class="text-3xl font-heading font-bold text-accent mb-2">{item.stat}</div>
            <h3 class="font-heading font-semibold text-primary mb-2">{item.label}</h3>
            <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Aanpak -->
  <section class="bg-background py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Onze aanpak"
        subtitle="Van intake tot rapportage – een volledig verzorgd traject op maat."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { step: '1', title: 'Intake & maatwerkontwerp', desc: 'We bespreken uw specifieke situatie, doelen en wensen. We ontwerpen een traject op maat voor uw organisatie.' },
          { step: '2', title: 'Digitale meting', desc: 'Medewerkers vullen de online vragenlijst in. Anoniem en vertrouwelijk. Drempelvrij en laagdrempelig.' },
          { step: '3', title: 'Individuele gesprekken', desc: 'Elk medewerker bespreekt zijn of haar resultaten in een persoonlijk gesprek. Volledig vertrouwelijk.' },
          { step: '4', title: 'Teamrapportage & advies', desc: 'U ontvangt een geanonimiseerde teamrapportage met aanbevelingen voor hr-beleid en leiderschapsontwikkeling.' },
        ].map((item) => (
          <div class="bg-surface rounded-xl p-6 shadow-md text-center">
            <div class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">
              {item.step}
            </div>
            <h3 class="font-heading font-semibold text-lg text-primary mb-3">{item.title}</h3>
            <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Geschikt voor -->
  <section class="bg-section-alt py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl text-primary mb-4">Geschikt voor alle sectoren</h2>
      <p class="text-muted mb-8">De in-company werkenergieanalyse is toegepast in diverse sectoren en organisaties van verschillende groottes.</p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Zorg & welzijn', 'Onderwijs', 'Overheid', 'Zakelijke dienstverlening', 'Industrie', 'Retail', 'Non-profit', 'IT & Tech'].map((sector) => (
          <span class="bg-white text-primary font-semibold text-sm px-4 py-2 rounded-full shadow-sm">{sector}</span>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Interesse in een in-company traject?"
    subtitle="Neem contact op voor een vrijblijvend gesprek over de mogelijkheden voor uw organisatie. Ik maak graag een offerte op maat."
    href={`${import.meta.env.BASE_URL}contact`}
    btnText="Vraag een offerte aan"
  />

</BaseLayout>
