---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

const loopbaanIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`;

const reintegratieIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`;

const outplacementIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`;

const werkenergieIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`;
---

<BaseLayout title="Home" description="Joep Lochtenberg – Loopbaancoach in Hilversum. Professionele begeleiding bij loopbaanvragen, re-integratie en outplacement.">

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Services Grid -->
  <section id="diensten" class="bg-background py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Mijn diensten"
        subtitle="Professionele begeleiding op maat, afgestemd op uw persoonlijke situatie en loopbaandoelen."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal" data-delay="0">
          <ServiceCard
            icon={loopbaanIcon}
            title="Loopbaancoaching"
            desc="Vastgelopen in uw huidige functie of op zoek naar een nieuwe uitdaging? Samen maken we uw loopbaanambities concreet en werken we aan een helder, haalbaar plan."
            href="/loopbaancoaching/"
          />
        </div>
        <div class="reveal" data-delay="1">
          <ServiceCard
            icon={reintegratieIcon}
            title="Re-integratie"
            desc="Begeleiding bij terugkeer naar werk na ziekte of arbeidsongeschiktheid. Zowel spoor 1 (eigen werkgever) als spoor 2 (andere werkgever) traject."
            href="/re-integratie/"
          />
        </div>
        <div class="reveal" data-delay="2">
          <ServiceCard
            icon={outplacementIcon}
            title="Outplacement"
            desc="Professionele begeleiding voor werknemers die de organisatie verlaten. Van oriëntatie op de arbeidsmarkt tot het vinden van een passende nieuwe baan."
            href="/outplacement"
          />
        </div>
        <div class="reveal" data-delay="3">
          <ServiceCard
            icon={werkenergieIcon}
            title="Werkenergieanalyse"
            desc="Inzicht in uw energiebronnen en werkstressoren. Een wetenschappelijk onderbouwd instrument dat u helpt uw werkplezier en vitaliteit te vergroten."
            href="/werkenergieanalyse/"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Werkenergieanalyse Highlight -->
  <section class="bg-primary text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4">Hoe werkt de Werkenergieanalyse?</h2>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">
          Een bewezen methode om uw werkvitaliteit in kaart te brengen en duurzame inzetbaarheid te versterken.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center reveal" data-delay="0">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="font-heading font-bold text-2xl text-white">1</span>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-3 text-gold">Meting & Analyse</h3>
          <p class="text-white/75 leading-relaxed">
            Via een uitgebreide vragenlijst brengen we uw werkstressoren en energiebronnen in kaart. Dit geeft een helder beeld van uw huidige werksituatie.
          </p>
        </div>
        <div class="text-center reveal" data-delay="1">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="font-heading font-bold text-2xl text-white">2</span>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-3 text-gold">Persoonlijk Gesprek</h3>
          <p class="text-white/75 leading-relaxed">
            We bespreken de resultaten in een persoonlijk coachingsgesprek. U krijgt inzicht in wat u energie geeft en wat energie kost in uw werk.
          </p>
        </div>
        <div class="text-center reveal" data-delay="2">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="font-heading font-bold text-2xl text-white">3</span>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-3 text-gold">Actieplan</h3>
          <p class="text-white/75 leading-relaxed">
            Op basis van de analyse stellen we samen een concreet actieplan op. Praktische stappen om uw werkplezier en vitaliteit duurzaam te verbeteren.
          </p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/werkenergieanalyse/" class="inline-block border-2 border-white text-white font-semibold px-7 py-3 rounded-full hover:bg-white hover:text-primary transition-colors">
          Meer over de Werkenergieanalyse
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Testimonials -->
  <section class="bg-section-alt py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Wat cliënten zeggen"
        subtitle="Ervaringen van mensen die ik heb mogen begeleiden in hun loopbaan."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <TestimonialCard
          quote="Joep heeft mij geholpen om mijn loopbaanrichting te bepalen op een moment dat ik het zelf niet meer zag zitten. Zijn rustige, persoonlijke aanpak gaf mij het vertrouwen dat ik nodig had om de stap te zetten."
          author="Marieke V."
          role="HR Manager, Amsterdam"
        />
        <TestimonialCard
          quote="Na een langdurig ziektetraject begeleidde Joep mij terug naar de arbeidsmarkt. Zijn kennis van re-integratie en zijn betrokken houding maakten het verschil. Ik heb nu een baan die écht bij me past."
          author="Thomas K."
          role="Projectleider, Utrecht"
        />
        <TestimonialCard
          quote="De werkenergieanalyse opende mijn ogen voor wat mij energie geeft in mijn werk. Dankzij de coaching van Joep heb ik concrete stappen gezet om meer voldoening uit mijn loopbaan te halen."
          author="Sandra M."
          role="Teamleider, Hilversum"
        />
      </div>
      <div class="text-center mt-10">
        <a href="/aanbevelingen" class="text-accent font-semibold hover:text-primary transition-colors inline-flex items-center gap-1">
          Lees alle aanbevelingen <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. About Teaser -->
  <section class="bg-background py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src={`${import.meta.env.BASE_URL}/images/joep.jpg`}
            alt="Joep Lochtenberg"
            class="rounded-2xl shadow-xl w-full max-w-sm mx-auto lg:mx-0"
          />
        </div>
        <div>
          <span class="text-accent font-semibold uppercase text-sm tracking-wider mb-3 block">Over mij</span>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-primary mb-5">Joep Lochtenberg</h2>
          <p class="text-muted leading-relaxed mb-4">
            Als gecertificeerd loopbaancoach en NOLOC-lid help ik mensen bij het maken van bewuste keuzes in hun loopbaan. Met meer dan 13 jaar ervaring heb ik honderden professionals begeleid bij loopbaanvragen, re-integratie en outplacement.
          </p>
          <p class="text-muted leading-relaxed mb-6">
            Mijn aanpak is persoonlijk, resultaatgericht en gebaseerd op bewezen coachingsmethodieken. Ik werk vanuit Hilversum en ontvang cliënten uit de hele regio Noord-Holland en daarbuiten.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="bg-section-alt text-primary font-semibold text-sm px-3 py-1 rounded-full">NOLOC gecertificeerd</span>
            <span class="bg-section-alt text-primary font-semibold text-sm px-3 py-1 rounded-full">RLP geregistreerd</span>
            <span class="bg-section-alt text-primary font-semibold text-sm px-3 py-1 rounded-full">SPHBO gecertificeerd</span>
            <span class="bg-section-alt text-primary font-semibold text-sm px-3 py-1 rounded-full">13+ jaar ervaring</span>
          </div>
          <a href="/joep" class="inline-block bg-primary text-white font-semibold px-7 py-3 rounded-full hover:bg-accent transition-colors">
            Meer over Joep
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA Section -->
  <CTASection
    title="Klaar om de volgende stap te zetten?"
    subtitle="Plan een vrijblijvend kennismakingsgesprek en ontdek hoe ik u kan begeleiden naar een loopbaan die écht bij u past."
    href="/contact"
    btnText="Plan een gratis kennismaking"
  />

</BaseLayout>
