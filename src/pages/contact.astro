---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Neem contact op met Joep Lochtenberg, loopbaancoach in Hilversum. Plan een vrijblijvend kennismakingsgesprek."
>

  <!-- Hero -->
  <section class="bg-primary text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading font-bold text-4xl md:text-5xl mb-4">Contact</h1>
      <p class="text-white/85 text-xl leading-relaxed">
        Neem contact op voor een vrijblijvend kennismakingsgesprek. Ik reageer binnen één werkdag.
      </p>
    </div>
  </section>

  <!-- Contact sectie -->
  <section class="bg-background py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Contactformulier -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-primary mb-6">Stuur een bericht</h2>
          <form action="#" method="POST" class="space-y-5">
            <div>
              <label for="naam" class="block text-sm font-semibold text-primary mb-1">
                Naam <span class="text-accent">*</span>
              </label>
              <input
                type="text"
                id="naam"
                name="naam"
                required
                placeholder="Uw volledige naam"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-primary mb-1">
                E-mailadres <span class="text-accent">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="uw@email.nl"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
              />
            </div>

            <div>
              <label for="telefoon" class="block text-sm font-semibold text-primary mb-1">
                Telefoonnummer
              </label>
              <input
                type="tel"
                id="telefoon"
                name="telefoon"
                placeholder="06-123 456 789"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
              />
            </div>

            <div>
              <label for="onderwerp" class="block text-sm font-semibold text-primary mb-1">
                Onderwerp
              </label>
              <select
                id="onderwerp"
                name="onderwerp"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-text focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition bg-white"
              >
                <option value="">Selecteer een onderwerp</option>
                <option value="loopbaancoaching">Loopbaancoaching</option>
                <option value="reintegratie">Re-integratie</option>
                <option value="outplacement">Outplacement</option>
                <option value="werkenergieanalyse">Werkenergieanalyse</option>
                <option value="in-company">In Company traject</option>
                <option value="overig">Overig</option>
              </select>
            </div>

            <div>
              <label for="bericht" class="block text-sm font-semibold text-primary mb-1">
                Bericht <span class="text-accent">*</span>
              </label>
              <textarea
                id="bericht"
                name="bericht"
                required
                rows="6"
                placeholder="Beschrijf kort uw situatie en uw vraag..."
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="privacy" name="privacy" required class="mt-1 accent-accent" />
              <label for="privacy" class="text-muted text-sm">
                Ik ga akkoord met het <a href={`${import.meta.env.BASE_URL}/privacy`} class="text-accent hover:underline">privacybeleid</a> en geef toestemming voor het verwerken van mijn gegevens.
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-accent text-white font-semibold py-3 px-6 rounded-full hover:bg-primary transition-colors shadow-md"
            >
              Verstuur bericht
            </button>
          </form>
        </div>

        <!-- Contactinfo + Kaart -->
        <div class="space-y-6">
          <div>
            <h2 class="font-heading font-bold text-2xl text-primary mb-6">Contactgegevens</h2>
          </div>

          <div class="bg-surface rounded-2xl p-6 shadow-md space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-section-alt rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">Adres</h3>
                <p class="text-muted text-sm">Hilversum, Noord-Holland</p>
                <p class="text-muted text-sm">Gesprekken op locatie of online</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-section-alt rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">Telefoon</h3>
                <a href="tel:06123456789" class="text-accent hover:text-primary transition-colors font-semibold">06-123 456 789</a>
                <p class="text-muted text-sm">Bereikbaar op werkdagen</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-section-alt rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">E-mail</h3>
                <a href="mailto:joep@joeplochtenberg.nl" class="text-accent hover:text-primary transition-colors font-semibold">joep@joeplochtenberg.nl</a>
                <p class="text-muted text-sm">Reactie binnen één werkdag</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-section-alt rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">Openingstijden</h3>
                <p class="text-muted text-sm">Maandag t/m vrijdag: 9:00 – 18:00</p>
                <p class="text-muted text-sm">Avondafspraken in overleg</p>
              </div>
            </div>
          </div>

          <!-- Google Maps embed -->
          <div class="rounded-2xl overflow-hidden shadow-md h-64">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d78125.37!2d5.1286!3d52.2291!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c62e5b99d4aa43%3A0x48b98e87fd6f1bda!2sHilversum!5e0!3m2!1snl!2snl!4v1699999999999!5m2!1snl!2snl"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Locatie Joep Lochtenberg – Hilversum"
            ></iframe>
          </div>

          <!-- LinkedIn link -->
          <div class="bg-surface rounded-xl p-4 shadow-sm flex items-center gap-4">
            <svg class="w-8 h-8 text-[#0077B5] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <div>
              <p class="text-primary font-semibold text-sm">Verbind op LinkedIn</p>
              <a href="https://www.linkedin.com/in/joeplochtenberg" target="_blank" rel="noopener noreferrer" class="text-accent text-sm hover:underline">linkedin.com/in/joeplochtenberg</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-section-alt py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-2xl text-primary mb-8 text-center">Veelgestelde vragen</h2>
      <div class="space-y-4">
        {[
          {
            vraag: 'Hoe lang duurt een gemiddeld traject?',
            antwoord: 'Dat hangt af van uw situatie en doelen. Een loopbaancoachingstraject duurt gemiddeld 3 tot 6 maanden met 6 tot 10 gesprekken. Een werkenergieanalyse bestaat uit 1 à 2 gesprekken.',
          },
          {
            vraag: 'Kan ik ook online gesprekken voeren?',
            antwoord: 'Ja, zeker. Alle gesprekken zijn ook online mogelijk via video (Zoom of Teams). Veel cliënten combineren gesprekken op locatie in Hilversum met online sessies.',
          },
          {
            vraag: 'Vergoedt mijn werkgever de coaching?',
            antwoord: 'Dit is afhankelijk van uw werkgever en situatie. Bij re-integratie vergoedt de werkgever vaak het traject. Bij loopbaancoaching is dit wisselend. Vraag gerust een offerte aan die u kunt voorleggen.',
          },
          {
            vraag: 'Is het eerste gesprek gratis?',
            antwoord: 'Ja. Het eerste kennismakingsgesprek is altijd vrijblijvend en gratis. We bespreken uw situatie en kijken of er een klik is. Pas daarna besluit u of u een traject wilt starten.',
          },
        ].map((faq) => (
          <details class="bg-white rounded-xl shadow-sm overflow-hidden group">
            <summary class="px-6 py-4 font-semibold text-primary cursor-pointer flex items-center justify-between list-none">
              {faq.vraag}
              <svg class="w-5 h-5 text-accent flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-muted text-sm leading-relaxed">
              {faq.antwoord}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // FAQ accordion exclusivity — close others when one opens
  const faqSection = document.querySelector('.bg-section-alt .space-y-4');
  if (faqSection) {
    faqSection.addEventListener('toggle', (e) => {
      const opened = e.target as HTMLDetailsElement;
      if (opened.open) {
        faqSection.querySelectorAll('details').forEach((d) => {
          if (d !== opened) d.removeAttribute('open');
        });
      }
    }, true);
  }
</script>
